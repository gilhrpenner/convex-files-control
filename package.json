{
  "name": "@gilhrpenner/convex-files-control",
  "description": "A convex files control component for Convex.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gilhrpenner/convex-files-control"
  },
  "homepage": "https://github.com/gilhrpenner/convex-files-control#readme",
  "bugs": {
    "url": "https://github.com/gilhrpenner/convex-files-control/issues"
  },
  "version": "0.5.6",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "keywords": [
    "convex",
    "component",
    "files",
    "storage",
    "upload",
    "download",
    "access-control"
  ],
  "type": "module",
  "scripts": {
    "dev": "run-p -r 'dev:*'",
    "dev:backend": "convex dev --typecheck-components",
    "dev:frontend": "cd example && vite --clearScreen false",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' -i '**/*.test.ts' -c 'npm run build:codegen' --initial",
    "predev": "path-exists .env.local dist || (npm run build && convex dev --once)",
    "build": "tsc --project ./tsconfig.build.json",
    "build:codegen": "npx convex codegen --component-dir ./src/component && npm run build",
    "build:clean": "rm -rf dist *.tsbuildinfo && npm run build:codegen",
    "verify:dist-esm": "node ./scripts/check-dist-esm.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --noEmit && tsc -p example && tsc -p example/convex",
    "lint": "eslint src/",
    "all": "run-p -r 'dev:*' 'test:watch'",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck --clearScreen false",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "preversion": "npm ci && npm run build:clean && run-p test lint typecheck verify:dist-esm",
    "prepublishOnly": "npm run build:clean && npm run verify:dist-esm",
    "alpha": "npm version prerelease --preid alpha && npm publish --tag alpha && git push --follow-tags",
    "release": "npm version patch && npm publish && git push --follow-tags",
    "version": "vim -c 'normal o' -c 'normal o## '$npm_package_version CHANGELOG.md && prettier -w CHANGELOG.md && git add CHANGELOG.md",
    "check": "npm run build:clean && npm run typecheck && npm run lint && npm run test && npm run verify:dist-esm"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@convex-dev/action-retrier": "^0.3.0",
    "convex-helpers": "^0.1.118"
  },
  "peerDependencies": {
    "convex": "^1.29.3",
    "react": "^18.3.1 || ^19.0.0"
  },
  "overrides": {
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.1",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "9.39.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "chokidar-cli": "3.0.0",
    "convex": "1.41.0",
    "convex-test": "0.0.53",
    "cpy-cli": "^6.0.0",
    "eslint": "9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "npm-run-all2": "8.0.4",
    "path-exists-cli": "2.0.0",
    "pkg-pr-new": "^0.0.75",
    "prettier": "3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js"
}
